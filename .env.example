# qBit Mobile Configuration

# --- App server ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# --- App authentication ---
# AUTH_MODE=basic (default) requires HTTP Basic auth on every /api request.
# AUTH_MODE=disabled exposes the app without auth — only safe on a trusted
# LAN. The server will print a warning at boot if AUTH_MODE is disabled
# while HOST is non-loopback.
AUTH_MODE=basic
APP_USERNAME=admin
APP_PASSWORD=

# --- Upstream qBittorrent ---
QBITTORRENT_HOST=localhost
QBITTORRENT_PORT=8080
# Leave blank to use qBittorrent's local-bypass mode.
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# --- Optional ---
# Set when running behind a reverse proxy that sets X-Forwarded-* headers.
# TRUST_PROXY=1
# Allow exactly one additional cross-origin web client.
# ALLOWED_ORIGIN=

# --- Move-to location presets ---
# Pre-populate the "Move" sheet with named target paths so phone users
# don't have to type server filesystem paths. Format:
#   Name1=/path1|Name2=/path2|Name3=/path3
# Example:
# DOWNLOAD_LOCATIONS=Movies=/mnt/media/movies|TV=/mnt/media/tv|Music=/mnt/media/music
DOWNLOAD_LOCATIONS=

# Dev proxy target (used by vite dev server)
QBIT_HOST=http://localhost:8080
